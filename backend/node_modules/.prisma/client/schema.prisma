datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum EventSource {
  gmail
  weather
  voice
  manual
}

enum EventStatus {
  pending
  confirmed
  rejected
}

model User {
  id                          String   @id @default(uuid())
  email                       String   @unique
  name                        String?
  googleRefreshTokenEncrypted String? // Encrypted AES-256-GCM
  location                    String? // Nullable user city/location (e.g. "Shanghai")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  events                      Event[]
}

model Event {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  location        String?
  source          EventSource
  status          EventStatus @default(pending)
  googleEventId   String? // Nullable, set when sync'd with Google Calendar
  confidence      Float? // AI extraction confidence level
  originalEmailId String? // Gmail message ID to prevent duplicate processing
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([userId, startTime])
  @@index([originalEmailId])
}
